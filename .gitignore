# Root .gitignore for TransitFlow Project

# Dependencies
node_modules/
*/node_modules/
**/node_modules/

# Environment variables
.env
.env.local
.env.*.local
*/.env
*/.env.local
**/.env.local

# Logs
*.log
logs/
*/logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build outputs
build/
dist/
*/build/
*/dist/
*.tgz

# Coverage
coverage/
*/coverage/
.nyc_output/

# IDEs and editors
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
*.sublime-workspace
*.sublime-project
.history/

# OS files
Thumbs.db
.DS_Store
.AppleDouble
.LSOverride
._*

# Temporary files
tmp/
temp/
*.tmp
*.temp

# Cache
.cache/
.eslintcache
.npm
.yarn/
.pnp.*

# Lock files (optional)
# Uncomment if you want to ignore lock files
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

# PM2 (for production)
.pm2/
ecosystem.config.js

# Database files (if added later)
*.sqlite
*.sqlite3
*.db

# Backup files
*.backup
*.bak
*~

# Verification scripts output
verify-output.txt