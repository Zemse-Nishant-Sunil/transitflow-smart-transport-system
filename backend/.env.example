# Backend example env - add real keys for production
PORT=5000
FRONTEND_URL=http://localhost:3000
NODE_ENV=development

# GTFS-RT optional
GTFS_RT_CITY=
GTFS_RT_FEED_URL=

# External API keys / endpoints
NOMINATIM_URL=https://nominatim.openstreetmap.org
IPAPI_URL=https://ipapi.co
OPENWEATHER_API_KEY=your_openweather_key
EXCHANGERATE_API_URL=https://api.exchangerate.host
CO2SIGNAL_API_KEY=your_co2signal_key
OPENROUTESERVICE_API_KEY=your_openrouteservice_key

# Free services added (no key usually required; override base urls if needed)
OPENMETEO_URL=https://api.open-meteo.com/v1/forecast
OSRM_URL=https://router.project-osrm.org
FRANKFURTER_URL=https://api.frankfurter.app
IPWHO_URL=https://ipwho.is
OWID_CO2_SOURCE=https://raw.githubusercontent.com/owid/co2-data/master/owid-co2-data.json

# GraphHopper (demo or self-host)
GRAPHOPPER_URL=https://graphhopper.com/api/1
GRAPHOPPER_API_KEY=

# ElectricityMap (optional API key, public endpoints may exist)
ELECTRICITYMAP_URL=https://api.electricitymap.org/v3
ELECTRICITYMAP_API_KEY=
